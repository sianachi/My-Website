# MongoDB — content API and the content:seed script.
# Local dev: `docker compose -f deployment/docker-compose.yml up -d`.
MONGODB_URI=mongodb://localhost:27017/portfolio

# WebAuthn relying party — admin passkey auth.
# RP_ID is the hostname (no scheme); RP_ORIGIN is the full origin the SPA loads from.
RP_ID=localhost
RP_NAME=Portfolio
RP_ORIGIN=http://localhost:5173

# S3-compatible storage (MinIO locally). Defaults match deployment/docker-compose.yml.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=portfolio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Optional. Base URL the browser uses when MinIO sits behind a different host
# (e.g. s3.example.com via reverse proxy). Defaults to S3_ENDPOINT.
# S3_PUBLIC_URL=
# S3_REGION=us-east-1

# Optional. API listen port in dev and prod. Defaults to 3001.
# PORT=3001
