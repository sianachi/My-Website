# Vercel Blob — required for /api/cv and the cv:upload script.
# Get from: Vercel dashboard → Storage → <your blob store> → .env.local tab
BLOB_READ_WRITE_TOKEN=

# MongoDB — required for the content API handlers and the content:seed script.
# Local dev: start the container with `docker compose -f deployment/docker-compose.yml up -d`.
MONGODB_URI=mongodb://localhost:27017/portfolio
