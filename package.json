{
  "name": "new-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "vite",
    "dev:api": "bun --watch run server/index.ts",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production bun run server/index.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "content:seed": "bun run scripts/seed-content.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@codemirror/lang-json": "^6.0.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@uiw/react-codemirror": "^4.25.9",
    "@vercel/analytics": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "dompurify": "^3.4.1",
    "express": "^5.2.1",
    "marked": "^18.0.2",
    "mongodb": "^7.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vercel": "^52.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.0.0",
    "turndown": "^7.2.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
